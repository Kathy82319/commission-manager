@baseUrl = http://localhost:8787

### 1. 註冊新使用者，驗證 Public ID 生成
# 點擊上方的 Send Request，觀察右側視窗的回傳結果
# 預期：success: true，並回傳一組 public_id (例如 CM-A1B2C3D)
PATCH {{baseUrl}}/api/users/u-test-001
Content-Type: application/json

{
  "line_id": "test_line_001",
  "display_name": "測試委託人A",
  "avatar_url": "",
  "bio": ""
}

### 2. 更新同一個使用者，驗證 Public ID 一致性
# 再次點擊 Send Request
# 預期：success: true，且回傳的 public_id 必須與上一個請求完全相同
PATCH {{baseUrl}}/api/users/u-test-001
Content-Type: application/json

{
  "line_id": "test_line_001",
  "display_name": "測試委託人A (已改名)",
  "avatar_url": "",
  "bio": ""
}

### 3. 建立第一筆委託單，驗證流水號
# 點擊 Send Request
# 預期：success: true，回傳的 id 格式應為 CM-XXXXXXX-001
POST {{baseUrl}}/api/commissions
Content-Type: application/json

{
  "client_id": "u-test-001",
  "total_price": 1000,
  "project_name": "測試專案A",
  "usage_type": "個人",
  "is_rush": "否",
  "delivery_method": "三階段",
  "payment_method": "匯款",
  "draw_scope": "半身",
  "char_count": 1,
  "bg_type": "無",
  "add_ons": "無",
  "detailed_settings": "無"
}

### 4. 建立第二筆委託單，驗證流水號遞增
# 再次點擊 Send Request
# 預期：success: true，回傳的 id 格式應為 CM-XXXXXXX-002
POST {{baseUrl}}/api/commissions
Content-Type: application/json

{
  "client_id": "u-test-001",
  "total_price": 2500,
  "project_name": "測試專案B",
  "usage_type": "商用",
  "is_rush": "是",
  "delivery_method": "三階段",
  "payment_method": "匯款",
  "draw_scope": "全身",
  "char_count": 1,
  "bg_type": "單色",
  "add_ons": "無",
  "detailed_settings": "無"
}