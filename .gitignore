# --- 系統與暫存檔 (避免 AI 掃描無用索引) ---
.DS_Store
Thumbs.db
*.swp
*.tmp
*.bak

# --- 依賴套件與建置產物 (最容易造成卡頓的主因) ---
node_modules/
/dist
/dist-ssr
/build
/out
/target
.cache/
.npm/
*.tsbuildinfo
.eslintcache

# --- Logs (日誌檔案) ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 環境變數與敏感資訊 (保護你的 API Key 與 Secret) ---
.env*
!.env.example
.dev.vars*
!.dev.vars.example
*.local
credentials.json
*.pem
*.key

# --- Cloudflare Wrangler 專屬 ---
.wrangler/
/miniflare/

# --- 編輯器相關 ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
.classpath
.project
.settings/

# --- Git 內部資料 ---
# 雖然 Git 本身不追蹤，但明確列出可防止某些掃描工具誤入
.git/

*.tsbuildinfo
worker-configuration.d.ts