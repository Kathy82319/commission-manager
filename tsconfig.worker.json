{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "types": [
      "@cloudflare/workers-types", 
      "node"
    ],
    // 🌟 解決報錯：加入這行忽略過時警告
    "ignoreDeprecations": "5.0", 
    // 🌟 現代化解析模式 (適合 Vite / Cloudflare)
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["worker/**/*.ts"]
}