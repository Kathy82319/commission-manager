{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    // 🌟 補上這行，解決你看到的報錯
    "module": "ESNext", 
    "types": [
      "@cloudflare/workers-types", 
      "node"
    ],
    "ignoreDeprecations": "5.0", 
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["worker/**/*.ts"]
}