{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "types": [
      "@cloudflare/workers-types", 
      "node"  // 🌟 必須要在這裡明確加上 node，TypeScript 才會在 Worker 環境認得 node:crypto
    ],
    "moduleResolution": "Node", // 確保模組解析方式是 Node
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["worker/**/*.ts"] 
}